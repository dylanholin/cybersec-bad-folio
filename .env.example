# Configuration DevFolio
# Copier ce fichier en .env et remplir les valeurs

DB_HOST=mariadb
DB_PORT=3306
DB_NAME=devfolio
DB_USER=devfolio_app
DB_PASSWORD=              # Mot de passe BDD (min 12 car., majuscule, chiffre, spécial)

JWT_SECRET=               # Générer avec : openssl rand -base64 48
JWT_EXPIRATION=3600000

# Origines autorisées pour CORS (séparées par des virgules, sans espace)
# En production, mettre l'URL publique du frontend (ex: https://<VPS_IP>)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

ADMIN_EMAIL=              # Email admin (ex: admin@devfolio.com)
ADMIN_PASSWORD=           # Mot de passe admin (min 12 car., majuscule, chiffre, spécial)

SMTP_HOST=smtp.example.com
SMTP_USER=
SMTP_PASSWORD=

AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
