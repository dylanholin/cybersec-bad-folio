# Forcer les fins de ligne LF pour les fichiers exécutés sous Linux.
# Évite l'erreur "$'\r': command not found" quand un .sh est édité sous Windows (CRLF).
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.properties text eol=lf
*.sql       text eol=lf

# Scripts batch Windows : garder CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
